# collection-api (backend) environment.
# Copy to `.env` and fill in real values. NEVER commit the real .env.

# Plex Media Server base URL (defaults to http://10.0.0.222:32400 if unset).
PLEX_URL=http://your-plex-host:32400

# Plex server token (X-Plex-Token).
PLEX_TOKEN=your-plex-token

# Admin key required by every /capi endpoint (X-Admin-Key header).
ADMIN_KEY=your-admin-key

# Access code for the Kelly Collection endpoints (X-Kelly-Key header).
KELLY_KEY=your-kelly-access-code
