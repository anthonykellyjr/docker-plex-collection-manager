# Copy this to .env. Don't commit the real one.

# Demo mode runs with fake data and no Plex. Set to 0 to use a real server.
DEMO_MODE=1

# Your Plex server. Needed when DEMO_MODE=0.
PLEX_URL=http://your-plex-host:32400
PLEX_TOKEN=your-plex-token

# The app's login key, sent as X-Admin-Key. Needed when DEMO_MODE=0.
ADMIN_KEY=change-me

# Host port for the web UI.
WEB_PORT=8080
